{
  "name": "qc-defect-tracking-system",
  "version": "1.0.0",
  "description": "ระบบรายงานและติดตามปัญหาคุณภาพชิ้นงาน (QC Defect Tracking System) — PWA + Cloudflare Workers/D1/R2 + LINE Messaging API",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
